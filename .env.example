# ============================================================
# 环境变量模板
# ============================================================
# 使用步骤：
#   git clone <repo>
#   cp .env.example .env
#   编辑 .env 填入真实配置
#   pytest
# ============================================================
# API 基础地址
BASE_URL=https://your-api-domain.com

# 登录接口地址
LOGIN_URL=/api/home/login/userLogin

# 登录账号
USERNAME=your_username

# 登录密码
PASSWORD=your_password

# Token 字段路径
TOKEN_FIELD=data.token

# Token 前缀（Bearer/Token/空）
TOKEN_TYPE=

# 认证请求头
AUTH_HEADER=Authorization

# 创建者用户ID
ORDER_CREATE_ID=your_user_id
